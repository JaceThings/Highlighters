{
  "name": "@highlighters/core",
  "version": "1.2.0",
  "description": "Framework-agnostic, realistic highlighter-pen marks for web text: multiline, deterministic, SSR-safe",
  "author": "Jace Attard <hi@ja.mt> (https://ja.mt)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./path": {
      "import": {
        "types": "./dist/path.d.ts",
        "default": "./dist/path.js"
      },
      "require": {
        "types": "./dist/path.d.cts",
        "default": "./dist/path.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaceThings/highlighters.git",
    "directory": "packages/core"
  },
  "keywords": [
    "highlighter",
    "highlight",
    "marker",
    "annotation",
    "mark",
    "text-highlight",
    "svg-filter",
    "mix-blend-mode"
  ],
  "homepage": "https://github.com/JaceThings/highlighters#readme",
  "bugs": "https://github.com/JaceThings/highlighters/issues",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
