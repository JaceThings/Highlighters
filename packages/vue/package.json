{
  "name": "@highlighters/vue",
  "version": "1.1.2",
  "description": "Vue composable and component for realistic highlighter marks",
  "author": "Jace Attard <hi@ja.mt> (https://ja.mt)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@highlighters/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaceThings/highlighters.git",
    "directory": "packages/vue"
  },
  "keywords": [
    "highlighter",
    "highlight",
    "marker",
    "vue",
    "composable",
    "component",
    "annotation"
  ],
  "homepage": "https://github.com/JaceThings/highlighters#readme",
  "bugs": "https://github.com/JaceThings/highlighters/issues",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "vue": "^3.5.28"
  }
}
