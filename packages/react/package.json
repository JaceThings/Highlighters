{
  "name": "@highlighters/react",
  "version": "1.2.0",
  "description": "React hook and component for realistic highlighter marks",
  "author": "Jace Attard <hi@ja.mt> (https://ja.mt)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@highlighters/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaceThings/highlighters.git",
    "directory": "packages/react"
  },
  "keywords": [
    "highlighter",
    "highlight",
    "marker",
    "react",
    "hook",
    "component",
    "annotation"
  ],
  "homepage": "https://github.com/JaceThings/highlighters#readme",
  "bugs": "https://github.com/JaceThings/highlighters/issues",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
