{
  "name": "@highlighters/svelte",
  "version": "0.0.0",
  "description": "Svelte action for realistic highlighter marks",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@highlighters/core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": ">=3.0.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/JaceThings/highlighters",
    "directory": "packages/svelte"
  },
  "keywords": [
    "highlighter",
    "highlight",
    "marker",
    "svelte",
    "action",
    "annotation"
  ],
  "homepage": "https://github.com/JaceThings/highlighters#readme",
  "bugs": "https://github.com/JaceThings/highlighters/issues",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
